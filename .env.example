APP_NAME=Laravel
APP_ENV=production
APP_KEY=base64:YOUR_KEY_HERE
APP_DEBUG=false
APP_URL=https://your-app-url

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ===================== DATABASE (CLOUD POSTGRESQL) =====================
DB_CONNECTION=pgsql
DB_HOST=ep-round-voice-a2pqksai.aws-eu-central-1.pg.laravel.cloud
DB_PORT=5432
DB_DATABASE=main
DB_USERNAME=laravel
DB_PASSWORD=npg_xQnJhY8CG3tl


# ===================== IMPORTANT FIX =====================
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ===================== FILESYSTEM =====================
FILESYSTEM_DISK=local

# ===================== CACHE/REDIS (désactivé pour éviter crash) =====================
